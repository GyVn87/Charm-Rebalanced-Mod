<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <LangVersion>10.0</LangVersion>
    <Nullable>enable</Nullable>
    <RootNamespace>TuyenTuyenTuyen</RootNamespace>
    <!--Replace this with your Managed folder path in Game Files folder-->
    <ManagedFolder>C:\Program Files (x86)\Steam\steamapps\common\Hollow Knight\hollow_knight_Data\Managed</ManagedFolder>
  </PropertyGroup>
    
  <Target Name="Copy DLLs" AfterTargets="Build">
    <Copy SourceFiles="$(TargetDir)\$(TargetName).dll;$(TargetDir)\$(TargetName).pdb" DestinationFolder="$(ManagedFolder)\Mods\Charm Rebalanced" />
    <Message Text="Successfully copied build files to $(ManagedFolder)\Mods\Charm Rebalanced" Importance="High" />
  </Target>
    
